sService.getProductById(id).subscribe({\r\n      next: (product) => (this.product = product),\r\n      error: () => (this.product = undefined),\r\n    });\r\n  }\r\n\r\n  backToList(): void {\r\n    this.router.navigate(['/produits']);\r\n  }\r\n\r\n  edit(): void {\r\n    if (this.product) {\r\n      this.router.navigate(['/produits', this.product.id, 'edit']);\r\n    }\r\n  }\r\n\r\n  availabilityLabel(availability: CatalogProduct['availability']): string {\r\n    return availability === 'In stock' ? 'En stock' : 'Rupture';\r\n  }\r\n}\r\n"],"sourceRoot":"webpack:///"}